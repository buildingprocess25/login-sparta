# Runtime
NODE_ENV=development
PORT=10000

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/sparta_login

# Security
# Use unique random values with at least 32 characters.
SESSION_SECRET=replace-with-minimum-32-character-secret
OTP_PEPPER=replace-with-minimum-32-character-otp-pepper

# CORS
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Email
GOOGLE_CLIENT_ID=replace-with-google-client-id
GOOGLE_CLIENT_SECRET=replace-with-google-client-secret
GOOGLE_REFRESH_TOKEN=replace-with-google-refresh-token
GMAIL_USER=replace-with-gmail-user@example.com

# Module SSO callbacks
SPARTA_BUILDING_CALLBACK_URL=http://localhost:5174/auth/sso/callback
SPARTA_MAINTENANCE_CALLBACK_URL=http://localhost:5175/auth/sso/callback
SPARTA_ENERGY_CALLBACK_URL=http://localhost:5176/auth/sso/callback
